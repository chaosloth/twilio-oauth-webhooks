# Twilio credentials
# Create an API Key at https://console.twilio.com/us1/account/keys-credentials/api-keys
# For Restricted API Keys (recommended), enable: Webhooks (Read & Write), Account Settings (Read)
# A Standard API Key also works and has access to all APIs including Preview
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OAuth 2.0 Authorization Server (used by Twilio to fetch tokens)
# Keycloak example (replace https://your-keycloak.ngrok.app with your ngrok URL):
#   OAUTH_TOKEN_URL=https://your-keycloak.ngrok.app/realms/master/protocol/openid-connect/token
# Auth0 example:
#   OAUTH_TOKEN_URL=https://YOUR_DOMAIN.auth0.com/oauth/token
# Entra example:
#   OAUTH_TOKEN_URL=https://login.microsoftonline.com/YOUR_TENANT_ID/oauth2/v2.0/token
OAUTH_TOKEN_URL=https://your-keycloak.ngrok.app/realms/master/protocol/openid-connect/token
OAUTH_CLIENT_ID=twilio-webhook-client
OAUTH_CLIENT_SECRET=your_client_secret
OAUTH_SCOPE=
OAUTH_AUDIENCE=

# Webhook server
WEBHOOK_PORT=3000
WEBHOOK_URL=https://your-webhook.ngrok.app/webhook

# JWKS for token validation (used by webhook servers to verify incoming tokens)
# Keycloak example:
#   OAUTH_JWKS_URI=https://your-keycloak.ngrok.app/realms/master/protocol/openid-connect/certs
# Auth0 example:
#   OAUTH_JWKS_URI=https://YOUR_DOMAIN.auth0.com/.well-known/jwks.json
# Entra example:
#   OAUTH_JWKS_URI=https://login.microsoftonline.com/YOUR_TENANT_ID/discovery/v2.0/keys
OAUTH_JWKS_URI=https://your-keycloak.ngrok.app/realms/master/protocol/openid-connect/certs
OAUTH_ISSUER=https://your-keycloak.ngrok.app/realms/master

# Managed by scripts (auto-populated by create-setting.sh and create-rule.sh)
WEBHOOK_SETTING_SID=
WEBHOOK_RULE_SID=
